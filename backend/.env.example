# Copy to .env and fill in. Railway injects DATABASE_URL / REDIS_URL automatically.
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,.railway.app
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app
CSRF_TRUSTED_ORIGINS=https://your-frontend.vercel.app

# Local dev leaves these blank -> SQLite + local-memory cache.
# Free deploy: set DATABASE_URL to a free Neon Postgres URL. REDIS_URL stays
# blank on free tier (the app falls back to in-memory cache automatically).
DATABASE_URL=
REDIS_URL=
MARKET_CACHE_TTL=90

# Admin user auto-created at deploy (Render build step) if both are set.
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=

# Manual PromptPay
PROMPTPAY_ID=0812345678
PROMPTPAY_NAME=Your Name

# Where Discord login sends the user back (your frontend origin).
FRONTEND_URL=http://localhost:3000

# Social auth (optional for MVP; fill both to enable Discord login)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
